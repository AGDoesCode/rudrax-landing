---
import Layout from "../layouts/Layout.astro";

const platforms = [
  {
    name: "Micro SaaS",
    description:
      "Focused web products that solve one problem well — subscription-ready, fast to ship, built to scale.",
    icon: "cloud",
  },
  {
    name: "Android",
    description:
      "Native Android experiences for users who live on their phones — polished, performant, Play Store ready.",
    icon: "android",
  },
  {
    name: "iOS",
    description:
      "Apps crafted for iPhone and iPad with the quality and simplicity Apple users expect.",
    icon: "apple",
  },
  {
    name: "Windows",
    description:
      "Desktop software for power users and professionals who need tools that stay on their machine.",
    icon: "windows",
  },
];

const principles = [
  {
    title: "Ship small, iterate fast",
    body: "Each product does one job exceptionally well. No bloated suites — just tools people actually use.",
  },
  {
    title: "Every platform, one brand",
    body: "Rudrax.AI is the home for our portfolio — web, mobile, and desktop under a single trusted umbrella.",
  },
  {
    title: "Built to last",
    body: "We design for reliability, clear pricing, and long-term support — not launch-day hype.",
  },
];
---

<Layout>
  <div class="page">
    <div class="bg-glow" aria-hidden="true"></div>
    <div class="bg-grid" aria-hidden="true"></div>

    <header class="header">
      <a href="/" class="logo">
        <span class="logo-mark">R</span>
        <span class="logo-text">Rudrax<span class="logo-ai">.AI</span></span>
      </a>
      <nav class="nav">
        <a href="#platforms">Platforms</a>
        <a href="#about">About</a>
        <a href="#contact" class="nav-cta">Get in touch</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <p class="eyebrow">Umbrella company · Software portfolio</p>
        <h1>
          Micro SaaS and apps<br />
          <span class="gradient-text">across every platform</span>
        </h1>
        <p class="hero-lead">
          Rudrax.AI builds and sells focused software — subscription web products,
          Android and iOS apps, and Windows desktop tools. One company, many products,
          each designed to earn its place on your home screen.
        </p>
        <div class="hero-actions">
          <a href="#platforms" class="btn btn-primary">See what we build</a>
          <a href="#contact" class="btn btn-secondary">Contact us</a>
        </div>
        <div class="hero-stats">
          <div class="stat">
            <span class="stat-value">4</span>
            <span class="stat-label">Platforms</span>
          </div>
          <div class="stat-divider" aria-hidden="true"></div>
          <div class="stat">
            <span class="stat-value">Micro</span>
            <span class="stat-label">SaaS first</span>
          </div>
          <div class="stat-divider" aria-hidden="true"></div>
          <div class="stat">
            <span class="stat-value">2026</span>
            <span class="stat-label">Launching portfolio</span>
          </div>
        </div>
      </section>

      <section id="platforms" class="section">
        <div class="section-head">
          <h2>What we build</h2>
          <p>
            From browser tabs to app stores to the taskbar — Rudrax.AI products meet
            users wherever they work.
          </p>
        </div>
        <div class="platform-grid">
          {
            platforms.map((platform) => (
              <article class="platform-card">
                <div class={`platform-icon platform-icon--${platform.icon}`}>
                  {platform.icon === "cloud" && (
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <path d="M7 18h10a4 4 0 0 0 .5-8 5.5 5.5 0 0 0-10.6 1.5A3.5 3.5 0 0 0 7 18z" />
                    </svg>
                  )}
                  {platform.icon === "android" && (
                    <svg viewBox="0 0 24 24" fill="currentColor">
                      <path d="M17.6 9.5l1.4-2.4a.5.5 0 0 0-.9-.4l-1.4 2.5a6.9 6.9 0 0 0-8.2 0L6.9 6.7a.5.5 0 1 0-.9.4l1.4 2.4A6.5 6.5 0 0 0 4 15.5h16a6.5 6.5 0 0 0-2.4-6zM9 13.2a1 1 0 1 1 0-2 1 1 0 0 1 0 2zm6 0a1 1 0 1 1 0-2 1 1 0 0 1 0 2z" />
                    </svg>
                  )}
                  {platform.icon === "apple" && (
                    <svg viewBox="0 0 24 24" fill="currentColor">
                      <path d="M16.7 12.7c0-2.5 2-3.7 2.1-3.8-1.1-1.7-2.9-1.9-3.5-2-1.5-.2-2.9.9-3.7.9s-1.9-.9-3.2-.9c-1.6 0-3.1.9-4 2.3-1.7 2.9-.4 7.2 1.2 9.6.8 1.2 1.8 2.5 3.1 2.4 1.2 0 1.7-.8 3.2-.8s1.9.8 3.2.8c1.3 0 2.1-1.2 2.9-2.4.9-1.3 1.3-2.6 1.3-2.7-.1 0-2.5-1-2.5-3.8zM14.5 5.8c.7-.8 1.1-1.9 1-3-.9 0-2 .6-2.7 1.4-.6.7-1.1 1.9-1 3 .9.1 2-.5 2.7-1.4z" />
                    </svg>
                  )}
                  {platform.icon === "windows" && (
                    <svg viewBox="0 0 24 24" fill="currentColor">
                      <path d="M3 5.5 10.5 4.2v7.4H3V5.5zm0 8.9h7.5v7.4L3 20.1V14.4zm9-9.3L21 3.9v8.7h-9V5.1zm0 9.3h9v8.7l-9-1.6v-7.1z" />
                    </svg>
                  )}
                </div>
                <h3>{platform.name}</h3>
                <p>{platform.description}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section id="about" class="section section--about">
        <div class="about-inner">
          <div class="about-copy">
            <h2>The Rudrax.AI model</h2>
            <p>
              We're not building one giant platform. We're building a portfolio of
              sharp, independent products — each with its own audience, pricing, and
              roadmap — united under one company you can trust.
            </p>
            <p class="about-note">
              Products are launching through 2026. This site will grow as our catalog does.
            </p>
          </div>
          <ul class="principles">
            {
              principles.map((item) => (
                <li>
                  <h3>{item.title}</h3>
                  <p>{item.body}</p>
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <section id="contact" class="section section--contact">
        <div class="contact-card">
          <h2>Work with us</h2>
          <p>
            Interested in our upcoming products, partnerships, or early access?
            We'd love to hear from you.
          </p>
          <a href="mailto:hello@rudrax.ai" class="btn btn-primary btn-lg">
            hello@rudrax.ai
          </a>
        </div>
      </section>
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <a href="/" class="logo logo--footer">
          <span class="logo-mark">R</span>
          <span class="logo-text">Rudrax<span class="logo-ai">.AI</span></span>
        </a>
        <p class="footer-copy">
          © {new Date().getFullYear()} Rudrax.AI. All rights reserved.
        </p>
      </div>
    </footer>
  </div>
</Layout>

<style>
  .page {
    position: relative;
    overflow-x: hidden;
  }

  .bg-glow {
    position: fixed;
    inset: -20% 0 auto;
    height: 60vh;
    background: radial-gradient(
      ellipse 80% 60% at 50% -10%,
      var(--accent-glow),
      transparent 70%
    );
    pointer-events: none;
    z-index: 0;
  }

  .bg-grid {
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 0%, black, transparent 75%);
    pointer-events: none;
    z-index: 0;
  }

  .header {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-weight: 600;
    font-size: 1.125rem;
  }

  .logo-mark {
    display: grid;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--accent), #818cf8);
    font-family: "JetBrains Mono", monospace;
    font-weight: 500;
    font-size: 1rem;
    color: white;
    box-shadow: 0 0 24px var(--accent-glow);
  }

  .logo-ai {
    color: var(--cyan);
    font-weight: 500;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    font-size: 0.9375rem;
    color: var(--text-muted);
  }

  .nav a:hover {
    color: var(--text);
  }

  .nav-cta {
    padding: 0.5rem 1rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    color: var(--text) !important;
  }

  .nav-cta:hover {
    border-color: var(--accent);
    background: var(--accent-soft);
  }

  main {
    position: relative;
    z-index: 1;
  }

  .hero {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 4rem 1.5rem 5rem;
    text-align: center;
  }

  .eyebrow {
    display: inline-block;
    margin-bottom: 1.25rem;
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }

  .hero h1 {
    font-size: clamp(2.25rem, 6vw, 3.75rem);
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
  }

  .gradient-text {
    background: linear-gradient(135deg, #a5b4fc, var(--cyan));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero-lead {
    max-width: 42rem;
    margin: 0 auto 2rem;
    font-size: 1.125rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
    margin-bottom: 3.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    border-radius: 999px;
    font-size: 0.9375rem;
    font-weight: 500;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--accent), #818cf8);
    color: white;
    box-shadow: 0 4px 24px var(--accent-glow);
  }

  .btn-primary:hover {
    box-shadow: 0 8px 32px var(--accent-glow);
  }

  .btn-secondary {
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    color: var(--text);
  }

  .btn-secondary:hover {
    border-color: rgba(148, 163, 184, 0.3);
  }

  .btn-lg {
    padding: 0.875rem 1.75rem;
    font-size: 1rem;
  }

  .hero-stats {
    display: inline-flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1rem 1.75rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: rgba(13, 20, 36, 0.6);
    backdrop-filter: blur(12px);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .stat-value {
    font-size: 1.125rem;
    font-weight: 600;
    font-family: "JetBrains Mono", monospace;
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .stat-divider {
    width: 1px;
    height: 2rem;
    background: var(--border);
  }

  .section {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .section-head {
    text-align: center;
    max-width: 36rem;
    margin: 0 auto 2.5rem;
  }

  .section-head h2 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }

  .section-head p {
    color: var(--text-muted);
    font-size: 1.0625rem;
  }

  .platform-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }

  .platform-card {
    padding: 1.5rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .platform-card:hover {
    border-color: rgba(99, 102, 241, 0.35);
    transform: translateY(-2px);
  }

  .platform-icon {
    width: 2.5rem;
    height: 2.5rem;
    margin-bottom: 1rem;
    color: var(--accent);
  }

  .platform-icon svg {
    width: 100%;
    height: 100%;
  }

  .platform-icon--android,
  .platform-icon--apple,
  .platform-icon--windows {
    color: var(--text-muted);
  }

  .platform-card h3 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .platform-card p {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .section--about {
    padding-top: 1rem;
    padding-bottom: 5rem;
  }

  .about-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
    padding: 2.5rem;
    border-radius: calc(var(--radius) + 4px);
    border: 1px solid var(--border);
    background: linear-gradient(180deg, var(--bg-elevated), rgba(13, 20, 36, 0.4));
  }

  .about-copy h2 {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
  }

  .about-copy p {
    color: var(--text-muted);
    margin-bottom: 1rem;
    line-height: 1.7;
  }

  .about-note {
    font-size: 0.875rem;
    font-style: italic;
    opacity: 0.85;
  }

  .principles {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .principles li {
    padding-left: 1rem;
    border-left: 2px solid var(--accent);
  }

  .principles h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.35rem;
  }

  .principles p {
    font-size: 0.9375rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .section--contact {
    padding-bottom: 6rem;
  }

  .contact-card {
    text-align: center;
    padding: 3rem 2rem;
    border-radius: calc(var(--radius) + 4px);
    border: 1px solid var(--border);
    background: radial-gradient(ellipse 80% 80% at 50% 100%, var(--accent-soft), transparent),
      var(--bg-elevated);
  }

  .contact-card h2 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .contact-card p {
    max-width: 28rem;
    margin: 0 auto 1.5rem;
    color: var(--text-muted);
  }

  .footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--border);
    padding: 2rem 1.5rem;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .logo--footer .logo-mark {
    width: 1.875rem;
    height: 1.875rem;
    font-size: 0.875rem;
  }

  .footer-copy {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .nav a:not(.nav-cta) {
      display: none;
    }

    .hero {
      padding-top: 2.5rem;
    }

    .hero-stats {
      flex-direction: column;
      gap: 1rem;
      width: 100%;
      max-width: 16rem;
    }

    .stat-divider {
      width: 2rem;
      height: 1px;
    }

    .about-inner {
      grid-template-columns: 1fr;
      padding: 1.5rem;
    }
  }
</style>
